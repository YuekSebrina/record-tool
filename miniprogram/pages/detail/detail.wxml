<navigation-bar title="记录详情" color="#202420" background="#f3efe4"></navigation-bar>

<view class="page-canvas page-canvas--detail detail-page">
  <view class="detail-meta">
    <text class="type-badge">{{entry.type === 'media' ? entry.mediaCategoryLabel : entry.typeLabel}}</text>
    <text>{{entry.statusLabel}}</text>
    <text>{{entry.timeLabel}}</text>
  </view>

  <text class="detail-content {{entry.completed && entry.type === 'todo' ? 'detail-content--completed' : ''}}">{{entry.content}}</text>

  <text wx:if="{{entry.detail}}" class="detail-note">{{entry.detail}}</text>

  <view wx:if="{{entry.type === 'media' && entry.progressText}}" class="progress-box">
    <view>
      <text>当前进度</text>
      <text>{{entry.progressText}}</text>
    </view>
    <view wx:if="{{entry.totalProgress > 0}}" class="progress-track">
      <view style="width: {{entry.currentProgress / entry.totalProgress * 100}}%"></view>
    </view>
  </view>

  <view class="created-time">
    <text>记录时间</text>
    <text>{{entry.recordedAt}}</text>
  </view>
</view>

<view class="detail-action-dock">
  <view class="action-menu {{actionMenuOpen ? 'action-menu--open' : ''}}">
    <view class="menu-action menu-action--danger" bindtap="confirmDelete">删除</view>
    <view class="menu-action" bindtap="editEntry">编辑</view>
    <view wx:if="{{entry.type === 'todo'}}" class="menu-action" bindtap="toggleTodo">
      {{entry.completed ? '重新打开' : '完成'}}
    </view>
    <view wx:if="{{entry.type === 'media' && entry.status !== 'completed'}}" class="menu-action" bindtap="completeMedia">完成</view>
    <view wx:if="{{entry.type === 'media' && entry.status === 'active' && (entry.mediaCategory === 'anime' || entry.mediaCategory === 'kdrama')}}" class="menu-action" bindtap="increaseProgress">进度 +1</view>
  </view>
  <view
    class="action-toggle {{actionMenuOpen ? 'action-toggle--open' : ''}}"
    bindtap="toggleActionMenu"
    aria-role="button"
    aria-label="{{actionMenuOpen ? '收起操作' : '展开操作'}}"
  >
    <view class="menu-chevron {{actionMenuOpen ? 'menu-chevron--left' : 'menu-chevron--down'}}"></view>
  </view>
</view>
