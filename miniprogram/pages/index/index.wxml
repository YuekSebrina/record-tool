<navigation-bar title="拾羽" back="{{false}}" color="#202124" background="#f5f5f5"></navigation-bar>

<view class="page-canvas search-page">
  <view class="page-heading">
    <text class="page-title">搜索收藏</text>
    <text class="page-description">从豆瓣找到喜欢的书和影视作品</text>
  </view>

  <view class="search-panel">
    <t-tabs value="{{searchType}}" theme="tag" space-evenly bind:change="selectSearchType">
      <t-tab-panel value="media" label="影视"></t-tab-panel>
      <t-tab-panel value="book" label="图书"></t-tab-panel>
    </t-tabs>

    <view wx:if="{{searchType === 'media'}}" class="media-segmented">
      <t-segmented
        block
        value="{{selectedMediaCategory}}"
        options="{{mediaCategories}}"
        bind:change="selectMediaCategory"
      ></t-segmented>
    </view>

    <view class="search-control">
      <t-search
        value="{{keyword}}"
        action="搜索"
        clearable
        shape="round"
        placeholder="输入作品名称"
        confirm-type="search"
        bind:change="handleKeywordChange"
        bind:submit="runSearch"
        bind:action-click="runSearch"
      ></t-search>
    </view>
  </view>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="result-item skeleton-item" wx:for="{{skeletonItems}}" wx:key="*this">
      <t-skeleton loading row-col="{{skeletonRows}}" animation="gradient"></t-skeleton>
    </view>
  </view>

  <view wx:elif="{{errorMessage}}" class="empty-state empty-state--error">
    <t-icon name="error-circle" size="72rpx" color="#d54941"></t-icon>
    <text class="empty-state__title">搜索没有完成</text>
    <text>{{errorMessage}}</text>
    <t-button theme="primary" shape="round" size="small" bind:tap="runSearch">重新搜索</t-button>
  </view>

  <view wx:elif="{{results.length}}" class="result-section">
    <view class="section-heading">
      <text>搜索结果</text>
      <text>{{results.length}} 个匹配</text>
    </view>
    <view class="result-list">
      <view class="result-item" wx:for="{{results}}" wx:key="id" data-id="{{item.id}}" bindtap="openResult">
        <view class="result-cover">
          <t-image
            wx:if="{{item.displayCover}}"
            src="{{item.displayCover}}"
            width="140rpx"
            height="190rpx"
            shape="round"
            mode="aspectFill"
            lazy
          ></t-image>
          <text wx:else>{{selectedCategoryMark}}</text>
        </view>
        <view class="result-info">
          <text class="result-title">{{item.title}}</text>
          <text wx:if="{{item.subtitle && item.subtitle !== item.title}}" class="result-subtitle">{{item.subtitle}}</text>
          <view class="result-meta">
            <t-tag wx:if="{{item.year}}" size="small" theme="default" variant="light">{{item.year}}</t-tag>
            <text wx:if="{{item.author}}">{{item.author}}</text>
            <text wx:if="{{item.episode}}">{{item.episode}}</text>
          </view>
        </view>
        <button
          class="collect-button {{item.favorited ? 'collect-button--saved' : ''}}"
          disabled="{{item.favorited}}"
          data-id="{{item.id}}"
          catchtap="addFavorite"
        >{{item.favorited ? '已收藏' : '+ 收藏'}}</button>
      </view>
    </view>
  </view>

  <view wx:elif="{{searched}}" class="empty-state">
    <t-icon name="search" size="76rpx" color="#b2b2b2"></t-icon>
    <text class="empty-state__title">没有找到相关作品</text>
    <text>试试简称、原名或更少的关键词</text>
  </view>

  <view wx:else class="search-guide">
    <view class="guide-icon"><t-icon name="heart" size="50rpx" color="#07c160"></t-icon></view>
    <text>输入名称，开始建立你的私人收藏</text>
  </view>
</view>

<view wx:if="{{detailVisible && selectedResult}}" class="detail-overlay" bindtap="closeDetail">
  <view class="detail-card" catchtap="preventDetailClose">
    <view class="detail-header">
      <view class="detail-cover">
        <t-image
          wx:if="{{selectedResult.displayCover}}"
          src="{{selectedResult.displayCover}}"
          width="176rpx"
          height="238rpx"
          shape="round"
          mode="aspectFill"
        ></t-image>
        <text wx:else>{{selectedCategoryMark}}</text>
      </view>
      <view class="detail-heading">
        <text class="detail-title">{{selectedResult.title}}</text>
        <text wx:if="{{selectedResult.subtitle && selectedResult.subtitle !== selectedResult.title}}" class="detail-subtitle">{{selectedResult.subtitle}}</text>
        <view class="detail-meta">
          <t-tag wx:if="{{selectedResult.year}}" size="small" variant="light">{{selectedResult.year}}</t-tag>
          <text wx:if="{{selectedResult.rating}}">豆瓣 {{selectedResult.rating}}</text>
          <text wx:if="{{selectedResult.author}}">{{selectedResult.author}}</text>
        </view>
        <text wx:if="{{detailGenres}}" class="detail-genres">{{detailGenres}}</text>
        <text wx:if="{{detailCreators}}" class="detail-genres">{{detailCreators}}</text>
      </view>
      <view class="detail-close" bindtap="closeDetail"><t-icon name="close" size="34rpx"></t-icon></view>
    </view>

    <view class="detail-body">
      <text class="detail-label">简介</text>
      <view wx:if="{{detailLoading}}" class="detail-loading">
        <t-skeleton loading theme="paragraph" animation="gradient"></t-skeleton>
      </view>
      <text wx:elif="{{selectedResult.description}}" class="detail-description">{{selectedResult.description}}</text>
      <text wx:else class="detail-empty">{{detailError || '暂无简介'}}</text>
    </view>

    <button
      class="detail-collect {{selectedResult.favorited ? 'detail-collect--saved' : ''}}"
      disabled="{{selectedResult.favorited || detailLoading}}"
      bindtap="addSelectedFavorite"
    >{{selectedResult.favorited ? '已收藏' : detailLoading ? '加载详情中' : '+ 加入收藏'}}</button>
  </view>
</view>

<bottom-nav active="search"></bottom-nav>
