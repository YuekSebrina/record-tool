<page-meta page-style="{{detailVisible || filterVisible ? 'overflow: hidden;' : ''}}"></page-meta>
<navigation-bar title="" back="{{false}}" color="#202124" background="transparent"></navigation-bar>

<view class="page-canvas search-page">
  <view class="page-heading">
    <view class="page-title-row">
      <text class="page-title">私人书影音收藏夹</text>
      <text class="title-sparkle">✦</text>
    </view>
    <text class="page-description">收藏热爱，记录美好</text>
  </view>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="result-item skeleton-item" wx:for="{{skeletonItems}}" wx:key="*this">
      <t-skeleton loading row-col="{{skeletonRows}}" animation="gradient"></t-skeleton>
    </view>
  </view>

  <view wx:elif="{{errorMessage}}" class="empty-state empty-state--error">
    <t-icon name="error-circle" size="72rpx" color="#d54941"></t-icon>
    <text class="empty-state__title">搜索没有完成</text>
    <text>{{errorMessage}}</text>
    <t-button theme="primary" shape="round" size="small" bind:tap="runSearch">重新搜索</t-button>
  </view>

  <view wx:elif="{{results.length}}" class="result-section">
    <view class="section-heading">
      <text>搜索结果</text>
      <text>{{results.length}} 个匹配</text>
    </view>
    <view class="result-list">
      <view class="result-item" wx:for="{{results}}" wx:key="resultKey" data-key="{{item.resultKey}}" bindtap="openResult">
        <view class="result-cover">
          <t-image
            wx:if="{{item.displayCover}}"
            src="{{item.displayCover}}"
            width="140rpx"
            height="190rpx"
            shape="round"
            mode="aspectFill"
            lazy
          ></t-image>
          <text wx:else>{{item.categoryMark}}</text>
        </view>
        <view class="result-info">
          <text class="result-title">{{item.title}}</text>
          <text wx:if="{{item.subtitle && item.subtitle !== item.title}}" class="result-subtitle">{{item.subtitle}}</text>
          <view class="result-meta">
            <t-tag size="small" theme="success" variant="light">{{item.categoryLabel}}</t-tag>
            <t-tag wx:if="{{item.year}}" size="small" theme="default" variant="light">{{item.year}}</t-tag>
            <text wx:if="{{item.author}}">{{item.author}}</text>
            <text wx:if="{{item.episode}}">{{item.episode}}</text>
          </view>
        </view>
        <button
          class="collect-button {{item.favorited ? 'collect-button--saved' : ''}}"
          disabled="{{item.favorited}}"
          data-key="{{item.resultKey}}"
          catchtap="addFavorite"
        >{{item.favorited ? '已收藏' : '+ 收藏'}}</button>
      </view>
    </view>
  </view>

  <view wx:elif="{{searched}}" class="empty-state">
    <t-icon name="search" size="76rpx" color="#b2b2b2"></t-icon>
    <text class="empty-state__title">没有找到相关作品</text>
    <text>试试简称、原名或更少的关键词</text>
  </view>

  <view wx:else class="home-content">
    <view class="trending-section">
      <view class="section-heading trending-heading">
        <text>近期热门</text>
        <text>实时更新</text>
      </view>
      <view wx:if="{{trendingLoading}}" class="trending-grid">
        <view
          class="trending-card trending-card--loading"
          wx:for="{{trendingSkeletons}}"
          wx:key="*this"
        ></view>
      </view>
      <view wx:elif="{{trendingItems.length}}" class="trending-grid">
        <view
          class="trending-card trending-card--{{item.category}}"
          wx:for="{{trendingItems}}"
          wx:key="resultKey"
          data-key="{{item.resultKey}}"
          bindtap="openTrending"
        >
          <text class="trending-category">{{item.categoryLabel}}</text>
          <text class="trending-title">{{item.title}}</text>
          <text wx:if="{{item.rating}}" class="trending-rating">{{item.rating}} 分</text>
          <view class="trending-cover">
            <image
              wx:if="{{item.displayCover}}"
              src="{{item.displayCover}}"
              class="trending-cover-image"
              mode="aspectFill"
              lazy-load="{{true}}"
            ></image>
            <text wx:else>{{item.categoryMark}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="trending-error" bindtap="loadTrending">{{trendingError}}</view>
    </view>

    <view class="recent-section">
      <view class="section-heading recent-heading">
        <text>最近收藏</text>
        <text bindtap="goToFavorites">查看全部 ></text>
      </view>
      <view wx:if="{{recentFavorites.length}}" class="recent-grid">
        <view
          class="recent-card"
          wx:for="{{recentFavorites}}"
          wx:key="favoriteId"
          bindtap="goToFavorites"
        >
          <view class="recent-cover">
            <image
              wx:if="{{item.displayCover}}"
              src="{{item.displayCover}}"
              class="recent-cover-image"
              mode="aspectFill"
              lazy-load="{{true}}"
            ></image>
            <text wx:else>{{item.categoryMark}}</text>
          </view>
          <text class="recent-title">{{item.title}}</text>
          <text class="recent-category">{{item.categoryLabel}}</text>
        </view>
      </view>
      <view wx:else class="welcome-card">
        <view>
          <text class="welcome-title">收藏你热爱的</text>
          <text class="welcome-copy">从一本书、一部电影开始</text>
        </view>
        <view class="welcome-mark">♡</view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{filterVisible}}" class="filter-overlay" bindtap="closeFilter">
  <view class="filter-panel" catchtap="preventFilterClose">
    <view class="filter-heading">
      <text>筛选搜索类别</text>
      <text>不选择则搜索全部</text>
    </view>
    <view class="filter-options">
      <view
        wx:for="{{filterOptions}}"
        wx:key="value"
        class="filter-option {{searchFilter === item.value ? 'filter-option--active' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectFilter"
      >
        <text>{{item.mark}}</text>
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>
</view>

<view class="search-dock" style="{{searchDockStyle}}">
  <view class="search-field">
    <t-icon name="search" size="34rpx" color="#a2a7a4"></t-icon>
    <input
      class="search-input"
      value="{{keyword}}"
      placeholder="{{searchPlaceholder}}"
      placeholder-class="search-placeholder"
      confirm-type="search"
      adjust-position="{{false}}"
      bindinput="handleKeywordChange"
      bindconfirm="runSearch"
      bindblur="handleSearchBlur"
      bindkeyboardheightchange="handleKeyboardHeightChange"
    />
    <view wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">
      <t-icon name="close-circle-filled" size="30rpx" color="#b5b8b6"></t-icon>
    </view>
    <view wx:if="{{hasKeyword}}" class="search-submit" bindtap="runSearch">搜索</view>
    <view class="filter-trigger {{searchFilter !== 'all' ? 'filter-trigger--active' : ''}}" bindtap="openFilter">
      <t-icon name="filter" size="34rpx" color="{{searchFilter !== 'all' ? '#07a950' : '#929895'}}"></t-icon>
      <text wx:if="{{searchFilter !== 'all'}}">{{filterLabel}}</text>
    </view>
  </view>
</view>

<view wx:if="{{detailVisible && selectedResult}}" class="detail-overlay" bindtap="closeDetail">
  <view class="detail-card" catchtap="preventDetailClose">
    <view class="detail-header">
      <view class="detail-cover">
        <t-image
          wx:if="{{selectedResult.displayCover}}"
          src="{{selectedResult.displayCover}}"
          width="176rpx"
          height="238rpx"
          shape="round"
          mode="aspectFill"
        ></t-image>
        <text wx:else>{{selectedResult.categoryMark}}</text>
      </view>
      <view class="detail-heading">
        <text class="detail-title">{{selectedResult.title}}</text>
        <text wx:if="{{selectedResult.subtitle && selectedResult.subtitle !== selectedResult.title}}" class="detail-subtitle">{{selectedResult.subtitle}}</text>
        <view class="detail-meta">
          <t-tag wx:if="{{selectedResult.year}}" size="small" variant="light">{{selectedResult.year}}</t-tag>
          <text wx:if="{{selectedResult.rating}}">豆瓣 {{selectedResult.rating}}</text>
          <text wx:if="{{selectedResult.author}}">{{selectedResult.author}}</text>
        </view>
        <text wx:if="{{detailGenres}}" class="detail-genres">{{detailGenres}}</text>
        <text wx:if="{{detailCreators}}" class="detail-genres">{{detailCreators}}</text>
      </view>
      <view class="detail-close" bindtap="closeDetail"><t-icon name="close" size="34rpx"></t-icon></view>
    </view>

    <view class="detail-body">
      <text class="detail-label">简介</text>
      <view wx:if="{{detailLoading}}" class="detail-loading">
        <t-skeleton loading theme="paragraph" animation="gradient"></t-skeleton>
      </view>
      <text wx:elif="{{selectedResult.description}}" class="detail-description">{{selectedResult.description}}</text>
      <text wx:else class="detail-empty">{{detailError || '暂无简介'}}</text>
    </view>

    <button
      class="detail-collect {{selectedResult.favorited ? 'detail-collect--saved' : ''}}"
      disabled="{{selectedResult.favorited || detailLoading}}"
      bindtap="addSelectedFavorite"
    >{{selectedResult.favorited ? '已收藏' : detailLoading ? '加载详情中' : '+ 加入收藏'}}</button>
  </view>
</view>

<bottom-nav active="search"></bottom-nav>
