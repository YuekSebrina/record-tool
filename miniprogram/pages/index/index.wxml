<navigation-bar title="拾羽" back="{{false}}" color="#202420" background="#f3efe4"></navigation-bar>

<view class="page-canvas home-page {{layoutScrollable ? 'home-page--scrolling' : ''}}">
  <view class="page-heading">
    <text class="page-heading__title">记点什么</text>
    <text class="page-heading__date">{{dateLabel}}</text>
  </view>

  <view class="composer" style="min-height: {{composerMinHeight}}px">
    <view class="type-tabs">
      <view
        class="type-tab {{selectedType === item.key ? 'type-tab--active' : ''}}"
        wx:for="{{typeOptions}}"
        wx:key="key"
        data-type="{{item.key}}"
        bindtap="selectType"
      >{{item.label}}</view>
    </view>

    <textarea
      class="composer-input"
      value="{{draft}}"
      placeholder="{{placeholder}}"
      placeholder-class="composer-input__placeholder"
      maxlength="500"
      auto-height="true"
      bindinput="handleDraftInput"
    ></textarea>

    <view wx:if="{{selectedType === 'media'}}" class="media-options">
      <view class="option-row">
        <view
          class="option-chip {{selectedMediaCategory === item.key ? 'option-chip--active' : ''}}"
          wx:for="{{mediaCategories}}"
          wx:key="key"
          data-category="{{item.key}}"
          bindtap="selectMediaCategory"
        >{{item.label}}</view>
      </view>
      <view class="option-row option-row--status">
        <view
          class="option-chip option-chip--quiet {{selectedMediaStatus === item.key ? 'option-chip--active' : ''}}"
          wx:for="{{mediaStatusOptions}}"
          wx:key="key"
          data-status="{{item.key}}"
          bindtap="selectMediaStatus"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="composer-footer">
      <text class="more-options" bindtap="openMoreOptions">更多选项</text>
      <button class="save-button" disabled="{{!draft}}" bindtap="saveQuickEntry">保存</button>
    </view>
  </view>

  <view class="section-heading">
    <text>最近记录</text>
    <text bindtap="openAll">查看全部</text>
  </view>

  <view wx:if="{{entries.length}}" class="entry-list recent-content">
    <view
      class="entry-row {{item.type === 'todo' && item.completed ? 'entry-row--completed' : ''}}"
      wx:for="{{entries}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="openEntry"
    >
      <view
        wx:if="{{item.type === 'todo'}}"
        class="todo-check {{item.completed ? 'todo-check--completed' : ''}}"
        data-id="{{item.id}}"
        catchtap="toggleTodo"
      >{{item.completed ? '✓' : ''}}</view>
      <view wx:else class="entry-mark">{{item.mark}}</view>

      <view class="entry-content">
        <text class="entry-text">{{item.content}}</text>
        <view class="entry-meta">
          <text>{{item.type === 'media' ? item.mediaCategoryLabel : item.typeLabel}}</text>
          <text>{{item.statusLabel}}</text>
          <text>{{item.progressText}}</text>
          <text>{{item.timeLabel}}</text>
        </view>
      </view>

      <view
        wx:if="{{item.type === 'media' && item.status === 'active' && (item.mediaCategory === 'anime' || item.mediaCategory === 'kdrama')}}"
        class="small-action"
        data-id="{{item.id}}"
        catchtap="increaseProgress"
        aria-role="button"
        aria-label="进度加一"
      >+1</view>
    </view>
  </view>

  <view wx:else class="empty-state recent-content">
    <text>还没有记录</text>
    <text>从上面的输入框开始就可以。</text>
  </view>
</view>

<view wx:if="{{previewVisible && selectedEntry}}" class="preview-overlay" bindtap="closePreview">
  <view class="preview-card" catchtap="preventClose">
    <view class="preview-header">
      <text class="preview-type">{{selectedEntry.type === 'media' ? selectedEntry.mediaCategoryLabel : selectedEntry.typeLabel}}</text>
      <text class="preview-status">{{selectedEntry.statusLabel}}</text>
    </view>
    <view class="preview-body">
      <view class="preview-copy">
        <text class="preview-content {{selectedEntry.type === 'todo' && selectedEntry.completed ? 'preview-content--completed' : ''}}">{{selectedEntry.content}}</text>
        <text wx:if="{{selectedEntry.detail}}" class="preview-detail">{{selectedEntry.detail}}</text>
      </view>
      <view wx:if="{{selectedEntry.type === 'media' && (selectedEntry.mediaCategory === 'anime' || selectedEntry.mediaCategory === 'kdrama')}}" class="preview-progress-panel {{selectedEntry.status !== 'active' ? 'preview-progress-panel--readonly' : ''}}">
        <text class="preview-progress-label">当前集数</text>
        <view class="preview-progress-value">
          <text class="preview-progress-current">{{selectedEntry.currentProgress}}</text>
          <text wx:if="{{selectedEntry.totalProgress > 0}}" class="preview-progress-total"> / {{selectedEntry.totalProgress}}</text>
          <text class="preview-progress-unit">集</text>
        </view>
        <view
          wx:if="{{selectedEntry.status === 'active'}}"
          class="preview-progress-add"
          bindtap="increasePreviewProgress"
          aria-role="button"
          aria-label="进度加一"
        >+1</view>
      </view>
    </view>
    <view class="preview-meta">
      <text>{{selectedEntry.timeLabel}}</text>
    </view>
    <view class="preview-actions">
      <view bindtap="closePreview">关闭</view>
      <view bindtap="openSelectedEntry">查看详情</view>
    </view>
  </view>
</view>

<bottom-nav id="home-bottom-nav" active="home"></bottom-nav>
