<navigation-bar title="云托管计数" back="{{false}}" color="#17211b" background="#f3efe4"></navigation-bar>

<view class="page-shell">
  <view class="eyebrow">WECHAT CLOUD RUN</view>
  <view class="hero">
    <text class="title">一次点击，写入云端</text>
    <text class="subtitle">请求经微信专线发送到 flask-tddl 服务，并由云托管 MySQL 持久化。</text>
  </view>

  <view class="counter-card">
    <view class="card-header">
      <text class="card-label">当前计数</text>
      <view class="status-dot status-dot--{{statusClass}}"></view>
    </view>

    <text class="count-value">{{hasCount ? count : '--'}}</text>
    <text class="status-text">{{statusText}}</text>

    <button
      class="count-button"
      bindtap="incrementCount"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '请求中' : '计数 +1'}}
    </button>

    <view wx:if="{{errorMessage}}" class="error-box">
      <text>{{errorMessage}}</text>
    </view>
  </view>

  <view class="service-info">
    <view class="info-row">
      <text class="info-label">环境</text>
      <text class="info-value">prod-d8gf33lii77ef34ef</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务</text>
      <text class="info-value">flask-tddl</text>
    </view>
    <view class="info-row">
      <text class="info-label">接口</text>
      <text class="info-value">POST /api/count</text>
    </view>
  </view>
</view>
