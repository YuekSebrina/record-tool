<navigation-bar title="拾羽" back="{{false}}" color="#202420" background="#f3efe4"></navigation-bar>

<view class="page-canvas profile-page">
  <view class="profile-card">
    <view class="avatar-placeholder">我</view>
    <view class="profile-copy">
      <text class="profile-name">未设置昵称</text>
      <text class="profile-caption">所有记录默认仅自己可见</text>
    </view>
    <text class="profile-action" bindtap="previewProfileSetup">设置</text>
  </view>

  <view class="statistics-card">
    <view class="statistic-item" wx:for="{{statistics}}" wx:key="label">
      <text>{{item.value}}</text>
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="todo-summary">
    <view>
      <text>待办完成情况</text>
      <text>{{completedTodoCount}} / {{totalTodoCount}}</text>
    </view>
    <view class="summary-track">
      <view style="width: {{totalTodoCount ? completedTodoCount / totalTodoCount * 100 : 0}}%"></view>
    </view>
  </view>

  <view class="privacy-note">
    <text>隐私说明</text>
    <text>当前记录只保存在本机原型中。接入微信登录后，云端数据仍默认仅本人可见。</text>
  </view>
</view>

<bottom-nav active="profile"></bottom-nav>
