<navigation-bar title="{{isEditing ? '编辑记录' : '新建记录'}}" color="#202420" background="#f3efe4"></navigation-bar>

<view class="page-canvas page-canvas--detail form-page">
  <view class="type-tabs">
    <view
      class="type-tab {{selectedType === item.key ? 'type-tab--active' : ''}}"
      wx:for="{{typeOptions}}"
      wx:key="key"
      data-type="{{item.key}}"
      bindtap="selectType"
    >{{item.label}}</view>
  </view>

  <view class="form-card">
    <text class="field-label">{{selectedType === 'note' ? '记录内容' : selectedType === 'todo' ? '待办事项' : '名称'}}</text>
    <textarea
      class="content-input"
      value="{{content}}"
      placeholder="{{selectedType === 'note' ? '写下一段话...' : selectedType === 'todo' ? '添加一件要做的事...' : '输入书名、电影或剧名...'}}"
      placeholder-class="input-placeholder"
      maxlength="500"
      auto-height="true"
      focus="{{!isEditing}}"
      bindinput="handleContentInput"
    ></textarea>
  </view>

  <view wx:if="{{selectedType === 'todo'}}" class="form-card compact-card">
    <view class="toggle-row" bindtap="toggleTodoCompleted">
      <view class="check-box {{todoCompleted ? 'check-box--active' : ''}}">{{todoCompleted ? '✓' : ''}}</view>
      <text>{{todoCompleted ? '已完成' : '待完成'}}</text>
    </view>
  </view>

  <view wx:if="{{selectedType === 'media'}}" class="form-card">
    <text class="field-label">分类</text>
    <view class="option-row">
      <view
        class="option-chip {{selectedMediaCategory === item.key ? 'option-chip--active' : ''}}"
        wx:for="{{mediaCategories}}"
        wx:key="key"
        data-category="{{item.key}}"
        bindtap="selectMediaCategory"
      >{{item.label}}</view>
    </view>

    <text class="field-label field-label--spaced">状态</text>
    <view class="option-row">
      <view
        class="option-chip {{selectedMediaStatus === item.key ? 'option-chip--active' : ''}}"
        wx:for="{{mediaStatusOptions}}"
        wx:key="key"
        data-status="{{item.key}}"
        bindtap="selectMediaStatus"
      >{{item.label}}</view>
    </view>

    <view wx:if="{{selectedMediaStatus === 'active' && (selectedMediaCategory === 'anime' || selectedMediaCategory === 'kdrama')}}" class="progress-row">
      <view class="number-field">
        <text>当前进度</text>
        <input type="number" value="{{currentProgress}}" bindinput="handleCurrentProgress" />
      </view>
      <view class="number-field">
        <text>总集数</text>
        <input type="number" value="{{totalProgress}}" bindinput="handleTotalProgress" />
      </view>
    </view>
  </view>

  <view class="form-card">
    <text class="field-label">补充说明</text>
    <input
      class="detail-input"
      value="{{detail}}"
      placeholder="选填，例如截止时间或一句备注"
      placeholder-class="input-placeholder"
      maxlength="100"
      bindinput="handleDetailInput"
    />
  </view>

  <view class="form-card">
    <text class="field-label">记录时间</text>
    <view class="date-row">
      <picker mode="date" value="{{date}}" bindchange="selectDate"><view>{{date}}</view></picker>
      <picker mode="time" value="{{time}}" bindchange="selectTime"><view>{{time}}</view></picker>
    </view>
  </view>

  <button class="primary-button" disabled="{{!content}}" bindtap="saveEntry">保存</button>
</view>
